{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning",
        "Grpc": "Warning",
        "System.Net.Http.HttpClient": "Warning"
      }
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "Processes": "Host=localhost;Port=5432;Database=processes;Username=postgres;Password=postgres"
  },
  "GrpcServices": {
    "Variables": "http://localhost:5100",
    "Worker": "http://localhost:5200",
    "WorkerHttpClientTimeout": "00:05:00",
    "ArtifactStorage": "http://localhost:5301"
  },
  "Deployment": {
    "LogPath": "logs/deployments",
    "ExecuteRequestTimeout": "00:05:00"
  },
  "Kestrel": {
    "Endpoints": {
      "Http": {
        "Url": "http://localhost:5092",
        "Protocols": "Http1"
      },
      "Grpc": {
        "Url": "http://localhost:5093",
        "Protocols": "Http2"
      }
    }
  }
}
